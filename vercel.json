{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<tenant>(?!www$)[a-z0-9-]+)\\.(?:myco-op|mycoop)\\.co\\.za"
        },
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|facebot|Twitterbot|twitterbot|Xbot|xbot|Slackbot|slackbot|LinkedInBot|linkedinbot|WhatsApp|whatsapp|TelegramBot|telegrambot|Discordbot|discordbot|SkypeUriPreview|skypeuripreview|Googlebot|googlebot|Bingbot|bingbot|Applebot|applebot|iMessagePreview).*"
        }
      ],
      "destination": "https://yhzajyegudbecyjpznjr.supabase.co/functions/v1/tenant-og?slug=:tenant"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
