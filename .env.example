## Shared
# Supabase (use your dev/prod project values as needed)
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

## App domains / multi-tenancy
# Production base domain (no protocol, no subdomain)
VITE_PROD_DOMAIN="myco-op.co.za"

# Tenant domain used for subdomain detection (e.g. aem.<tenant_domain>)
# - production: "myco-op.co.za"
# - local subdomain dev: "localhost" (e.g. aem.localhost)
VITE_TENANT_DOMAIN="myco-op.co.za"

# How tenant URLs should be constructed when navigating locally
# - "path":   http://localhost:8080/t/<slug>
# - "subdomain": http://<slug>.localhost:8080
VITE_TENANT_ROUTING="path"

# Local dev tenant domain for subdomain routing (only used when VITE_TENANT_ROUTING="subdomain")
VITE_DEV_TENANT_DOMAIN="localhost"
